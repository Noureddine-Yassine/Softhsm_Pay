' ============================================================
' 3. DIAGRAMME DE SÉQUENCE — Démarrage du HSM
' ============================================================

@startuml Sequence_Startup
!theme plain
skinparam sequenceArrowColor #2980B9
skinparam sequenceLifeLineBorderColor #1A5276
skinparam sequenceParticipantBackgroundColor #EBF5FB
skinparam sequenceParticipantBorderColor #2980B9
skinparam noteBorderColor #E67E22
skinparam noteBackgroundColor #FDEBD0

title Diagramme de Séquence — Démarrage du HSM (payhsm_startup)

actor "Administrateur" as Admin
participant "payhsmd\n(Daemon)" as Daemon
participant "payhsm_core" as Core
participant "DefenseModule" as Defense
participant "KekProvider" as KEK
participant "LmkStore" as LMK
participant "XorFragment" as Frag
participant "Integrity" as Integ
participant "KeyVault" as Vault
participant "SeccompPolicy" as Seccomp

Admin -> Daemon : payhsm startup <passphrase> <datadir>
activate Daemon

Daemon -> Core : payhsm_startup(passphrase, data_dir)
activate Core

Core -> Defense : anti_dump_setup()
note right : Désactive core dumps\nmlock(MCL_CURRENT|MCL_FUTURE)\nHandlers signaux fatals

Core -> Defense : anti_ptrace_setup()
note right : prctl(PR_SET_DUMPABLE,0)\nprctl(PR_SET_NO_NEW_PRIVS,1)

Core -> Seccomp : install_seccomp_filter()
note right : Filtre BPF whitelist\nsyscalls autorisés seulement

Core -> LMK : lmk_store_read_salt(lmk_path, salt)
activate LMK
LMK --> Core : salt[16]
deactivate LMK

Core -> KEK : kek_derive_from_passphrase(passphrase, salt, kek_out)
activate KEK
note right : PBKDF2-SHA256\n100 000 itérations
KEK --> Core : kek[32]
deactivate KEK

Core -> LMK : lmk_store_load(lmk_path, kek, lmk_out)
activate LMK
note right : AES-256-GCM\nDéchiffrement + vérification tag
LMK --> Core : lmk[32]
deactivate LMK

Core -> Defense : secure_zero(kek, 32)
note right : KEK effacé immédiatement

Core -> Frag : fragment_lmk(lmk)
activate Frag
note right : P1 (.bss)\nP2 (heap)\nP3 (.data)\nLMK XORée et effacée
Frag --> Core : 0 (OK)
deactivate Frag

Core -> Defense : secure_zero(lmk, 32)
note right : LMK effacée après fragmentation

Core -> Integ : integrity_set_reference(lmk_snapshot)
activate Integ
Integ --> Core : HMAC-SHA256 référence stocké
deactivate Integ

Core -> Vault : vault_load(vault_path)
activate Vault
Vault --> Core : clés chargées (TPK/TAK/ZMK/ZPK/PVK/IMK)
deactivate Vault

Core --> Daemon : PAYHSM_RC_OK
deactivate Core

Daemon --> Admin : "HSM opérationnel — boot_id=N"
deactivate Daemon

@enduml


' ============================================================
' 4. DIAGRAMME DE SÉQUENCE — Vérification PIN (Transaction GAP)
' ============================================================

@startuml Sequence_PIN_Verify
!theme plain
skinparam sequenceArrowColor #2980B9
skinparam sequenceLifeLineBorderColor #1A5276
skinparam sequenceParticipantBackgroundColor #EBF5FB
skinparam sequenceParticipantBorderColor #2980B9
skinparam noteBorderColor #E67E22
skinparam noteBackgroundColor #FDEBD0

title Diagramme de Séquence — Vérification PIN Block (Flux GAP → HSM)

actor "Porteur de Carte" as Cardholder
participant "Terminal GAP" as GAP
participant "Switch\nBancaire" as Switch
participant "payhsm_core\n(HSM Acquéreur)" as HSM_Acq
participant "XorFragment" as Frag
participant "KeyVault" as Vault
participant "PinModule" as Pin
participant "payhsm_core\n(HSM Émetteur)" as HSM_Iss

Cardholder -> GAP : Insère carte + saisie PIN

GAP -> GAP : Génère PIN Block ISO 9564 Fmt0\n(chiffré sous TPK local)

GAP -> Switch : Requête autorisation\n+ PIN Block(TPK) + PAN + Montant

Switch -> HSM_Acq : payhsm_translate_pin_to_zpk(terminal_id,\npin_block_tpk, pin_block_zpk)
activate HSM_Acq

HSM_Acq -> Frag : check_integrity()
note right : Vérification HMAC\navant toute opération
Frag --> HSM_Acq : OK

HSM_Acq -> Frag : recompose_for_op(lmk)
Frag --> HSM_Acq : lmk[32] (temporaire)

HSM_Acq -> Vault : vault_find(TPK, terminal_id)
Vault --> HSM_Acq : enc_tpk

HSM_Acq -> Vault : vault_decrypt_under_lmk(lmk, enc_tpk, tpk)
Vault --> HSM_Acq : tpk[16]

HSM_Acq -> Vault : vault_find(ZPK, ...)
Vault --> HSM_Acq : enc_zpk

HSM_Acq -> Vault : vault_decrypt_under_lmk(lmk, enc_zpk, zpk)
Vault --> HSM_Acq : zpk[16]

HSM_Acq -> Pin : translate_pin_block(pin_block_tpk, pan,\ntpk, 16, zpk, 16, pin_block_zpk)
note right : Déchiffre sous TPK\nRe-chiffre sous ZPK\nPIN jamais en clair
Pin --> HSM_Acq : pin_block_zpk[8]

HSM_Acq -> Frag : secure_zero(lmk,32) & secure_zero(tpk,16) & secure_zero(zpk,16)

HSM_Acq --> Switch : pin_block_zpk
deactivate HSM_Acq

Switch -> HSM_Iss : payhsm_verify_pin_block_zpk(zpk_key_id,\npan, pin_block_zpk, rc_out)
activate HSM_Iss

HSM_Iss -> Frag : check_integrity()
Frag --> HSM_Iss : OK
HSM_Iss -> Frag : recompose_for_op(lmk)
Frag --> HSM_Iss : lmk[32]

HSM_Iss -> Vault : vault_decrypt_under_lmk(lmk, enc_zpk_iss, zpk_iss)
Vault --> HSM_Iss : zpk_iss[16]

HSM_Iss -> Vault : vault_decrypt_under_lmk(lmk, enc_pvk, pvk)
Vault --> HSM_Iss : pvk[16]

HSM_Iss -> Pin : verify_encrypted_pin_block(pin_block_zpk, pan,\nzpk_iss, 16, pvk, 16, pvv_stored)
note right : Déchiffre PIN Block\nCalcule PVV\nCompare à PVV stocké\n(temps constant)
Pin --> HSM_Iss : 0 (valide) ou -1 (refus)

HSM_Iss -> Frag : secure_zero(...) — tous les secrets effacés

HSM_Iss --> Switch : rc_out (0=OK / 55=DECLINED)
deactivate HSM_Iss

Switch --> GAP : Autorisation (Approbation ou Refus)
GAP --> Cardholder : "Transaction APPROUVÉE / REFUSÉE"

@enduml


' ============================================================
' 5. DIAGRAMME DE SÉQUENCE — Paiement EMV complet
' ============================================================

@startuml Sequence_EMV_Purchase
!theme plain
skinparam sequenceArrowColor #2980B9
skinparam sequenceLifeLineBorderColor #1A5276
skinparam sequenceParticipantBackgroundColor #EBF5FB
skinparam sequenceParticipantBorderColor #2980B9

title Diagramme de Séquence — Simulation Paiement EMV

participant "Application\nBancaire" as App
participant "payhsm_core" as Core
participant "XorFragment" as Frag
participant "KeyVault" as Vault
participant "EmvModule" as EMV
participant "DefenseModule" as Defense

App -> Core : payhsm_emv_simulate_purchase(pan, psn,\natc_hex, amount_cents, currency_code3, result)
activate Core

Core -> Frag : check_integrity()
Frag --> Core : OK

Core -> Frag : recompose_for_op(lmk)
Frag --> Core : lmk[32]

Core -> Vault : vault_find(IMK, ...) + vault_decrypt_under_lmk
Vault --> Core : imk[16]

Core -> Defense : secure_zero(lmk, 32)

Core -> EMV : derive_card_keys(imk, 16, pan, psn, mk_ac_out)
note right : Méthode A EMV Book 2\nHMAC-SHA1(IMK, PAN||PSN)
EMV --> Core : mk_ac[16]

Core -> EMV : emv_build_tx_data(amount_cents, currency_code3,\ndate, atc_hex, terminal_id, tx_out, ...)
EMV --> Core : tx_data[]

Core -> EMV : derive_sk_ac(mk_ac, atc, sk_ac_out)
note right : Clé de session\nUnique par transaction
EMV --> Core : sk_ac[16]

Core -> EMV : emv_compute_arqc(sk_ac, tx_data, tx_len, arqc_out)
note right : CMAC(SK-AC, données tx)\n= Cryptogramme carte
EMV --> Core : arqc[8]

Core -> EMV : verify_arqc(sk_ac, tx_data, tx_len, arqc_out)
note right : Vérification côté HSM\némétteur
EMV --> Core : 0 (valide)

Core -> EMV : generate_arpc(mk_ac, arqc, auth_response_ARC, arpc_out)
note right : Réponse d'autorisation\npour la puce carte
EMV --> Core : arpc[8]

Core -> Defense : secure_zero(mk_ac,16) & secure_zero(sk_ac,16) & secure_zero(imk,16)

Core -> Core : Rempli payhsm_emv_purchase_t\n(rc=0, approved=1, arqc_hex, arpc_hex, amount_display)

Core --> App : result (rc=0, approved=true, arqc_hex, arpc_hex)
deactivate Core

@enduml


' ============================================================
' 6. DIAGRAMME D'ACTIVITÉ — Provisionnement du HSM
' ============================================================

@startuml Activity_Provision
!theme plain
skinparam activityBorderColor #2980B9
skinparam activityBackgroundColor #EBF5FB
skinparam activityDiamondBackgroundColor #FDEBD0
skinparam activityDiamondBorderColor #E67E22
skinparam arrowColor #1A5276

title Diagramme d'Activité — Provisionnement PayHSM

start

:Reçoit (passphrase, data_dir, terminaux[]);

:anti_dump_setup() — désactive dumps\nmlockall() — mémoire verrouillée;

:anti_ptrace_setup() — bloque debugger\ninstall_seccomp_filter() — syscalls filtrés;

:Créer/vérifier le répertoire data_dir;

:Générer LMK aléatoire 256 bits\nopenssl RAND_bytes(lmk, 32);

:Générer sel aléatoire 128 bits\nopenssl RAND_bytes(salt, 16);

:Dériver KEK depuis passphrase + sel\nPBKDF2-SHA256 (100 000 itérations);

:Chiffrer LMK sous KEK\nAES-256-GCM (nonce aléatoire + tag);

:Persister lmk.bin (salt + nonce + tag + CT);

:secure_zero(kek) — effacer KEK;

:integrity_set_reference(lmk)\nHMAC-SHA256 de la LMK entière;

:fragment_lmk(lmk)\n→ P1 (BSS), P2 (heap), P3 (data)\nP1 ⊕ P2 ⊕ P3 = LMK;

:secure_zero(lmk) — effacer LMK originale;

if (Terminaux fournis ?) then (oui)
  :Pour chaque terminal_id :
  - Générer TMK aléatoire
  - Dériver TPK = AES-CMAC(TMK, terminal_id||"TPK")
  - Dériver TAK = AES-CMAC(TMK, terminal_id||"TAK")
  - Calculer KCV(TPK), KCV(TAK)
  - recompose_for_op(lmk) temporairement
  - Chiffrer TMK/TPK/TAK sous LMK
  - secure_zero(lmk,tmk,tpk,tak)
  - vault_add_key(...);
else (non — LMK only)
  :Coffre HSM vide\nclés gérées par le Switch;
endif

:Persister keys.vault (chiffré sous LMK);

:Afficher "HSM provisionné\nTerminaux : N, Boot-ID : 1";

stop

@enduml


' ============================================================
' 7. DIAGRAMME D'ACTIVITÉ — Translation PIN TPK → ZPK
' ============================================================

@startuml Activity_PIN_Translation
!theme plain
skinparam activityBorderColor #2980B9
skinparam activityBackgroundColor #EBF5FB
skinparam activityDiamondBackgroundColor #FDEBD0
skinparam activityDiamondBorderColor #E67E22
skinparam arrowColor #1A5276

title Diagramme d'Activité — Translation PIN Block TPK → ZPK

start

:Reçoit (terminal_id, pin_block_tpk[8]);

:Vérifier que HSM est initialisé\n(g_ctx.initialized == 1);

if (HSM initialisé ?) then (non)
  :Retourner PAYHSM_RC_NOT_INIT;
  stop
endif

:check_integrity()\nHMAC-SHA256(P1⊕P2⊕P3) vs référence;

if (Intégrité fragments OK ?) then (non)
  :emergency_shutdown("fragments corrompus");
  stop
endif

:recompose_for_op(lmk)\n— P1 ⊕ P2 ⊕ P3 → LMK temporaire;

:vault_find(TPK, terminal_id)\nvault_decrypt_under_lmk(lmk, enc_tpk, tpk);

:vault_find(ZPK, ...)\nvault_decrypt_under_lmk(lmk, enc_zpk, zpk);

:secure_zero(lmk, 32)\n— LMK effacée immédiatement;

:pin_decrypt_block(tpk, 16, pin_block_tpk, pin_plain)\nDéchiffrement AES-128-ECB;

:Extraire PIN depuis pin_plain\n(Format ISO 9564 Fmt0 : nibbles);

:pin_build_clear_block(pin, pan, clear_block)\nConstruction bloc clair avec PAN;

:AES-128-ECB chiffrement sous ZPK\n→ pin_block_zpk[8];

:secure_zero(tpk, 16)\nsecure_zero(zpk, 16)\nsecure_zero(pin_plain, 8);

:Retourner pin_block_zpk[8];

stop

@enduml


' ============================================================
' 8. DIAGRAMME D'ARCHITECTURE (Component)
' ============================================================

@startuml Architecture_PayHSM
!theme plain
skinparam componentBackgroundColor #EBF5FB
skinparam componentBorderColor #2980B9
skinparam componentFontStyle bold
skinparam packageBackgroundColor #FDFEFE
skinparam packageBorderColor #AEB6BF
skinparam interfaceBackgroundColor #D5F5E3
skinparam interfaceBorderColor #27AE60
skinparam arrowColor #1A5276
skinparam databaseBackgroundColor #FDEBD0
skinparam databaseBorderColor #E67E22
skinparam noteBackgroundColor #FEF9E7
skinparam noteBorderColor #F39C12

title Diagramme d'Architecture — PayHSM (vue composants)

' ---- Couche Applications Clientes ----
package "Applications Clientes" {
  [Application Bancaire\n(Core Banking)] as BankApp
  [Terminal de Paiement\n(GAP / EPP)] as Terminal
  [Switch Inter-Bancaire] as Switch
  [payhsm-cli\n(CLI)] as CLI
  [payhsm-httpd\n(REST HTTP)] as HTTPD
}

' ---- Interface PKCS#11 ----
interface "PKCS#11\nC ABI" as PKCS11_IF
note right of PKCS11_IF
  PayHSM_PIN_translate()
  PayHSM_ARQC_verify()
  PayHSM_MAC_calculate()
  PayHSM_is_ready()
end note

' ---- Couche Dispatch ----
package "PayHSM — Couche Dispatch" {
  [payhsmd\n(Daemon Unix Socket)] as Daemon
  [payhsm_core\n(Opérations HSM)] as Core
  [payhsm_switch\n(Mode Switch)] as SwitchLayer
}

' ---- Couche Paiement ----
package "Couche Paiement (payment/)" {
  [pin.c\nISO 9564 Fmt0\nPIN Block / PVV] as PIN
  [mac.c\nISO 9797-1 Algo3\nRetail MAC / ZAK] as MAC
  [emv.c\nEMV Book 2\nARQC/ARPC/MK-AC/SK-AC] as EMV
  [key_exchange.c\nTPK/TAK/ZPK/ZMK\nKCV / PBKDF2] as KE
}

' ---- Couche Gestion des Clés ----
package "Couche Gestion des Clés (keymanager/)" {
  [xor_fragment.c\nFragmentation LMK\nP1⊕P2⊕P3] as XOR
  [lmk_store.c\nAES-256-GCM\nlmk.bin] as LMKS
  [kek_provider.c\nPBKDF2-SHA256\n100k itérations] as KEK
  [key_vault.c\nCoffre des clés\nkeys.vault] as VAULT
  [integrity.c\nHMAC-SHA256\nVérification fragments] as INTEG
  [mutation.c\nMutation cyclique XOR\n+ Shuffle heap P2] as MUT
}

' ---- Couche Défense ----
package "Couche Défense (defense/)" #FFE8E8 {
  [defense.c\nAnti-dump / Anti-ptrace\nSecure Zero / Handlers] as DEF
  [seccomp_policy.c\nFiltre BPF\nWhitelist syscalls] as SECC
}

' ---- Stockage Persistant ----
database "Stockage\nPersistant" as Storage {
  [lmk.bin\n(AES-256-GCM)] as LMKFile
  [keys.vault\n(chiffré sous LMK)] as VaultFile
  [cards.pvv\n(PVV par PAN)] as PVVFile
}

' ---- OpenSSL ----
[OpenSSL 3.x\n(AES / HMAC / CMAC\nRAND / PBKDF2)] as OSSL

' ---- Relations Clientes ----
BankApp --> PKCS11_IF
Terminal --> Daemon : Unix Socket
Switch --> SwitchLayer : API C directe
CLI --> Daemon : Unix Socket
HTTPD --> Core : appels directs

' ---- Dispatch interne ----
PKCS11_IF --> Core
Daemon --> Core
Core --> SwitchLayer

' ---- Couche paiement ----
Core --> PIN
Core --> MAC
Core --> EMV
Core --> KE
SwitchLayer --> PIN
SwitchLayer --> MAC
SwitchLayer --> EMV
SwitchLayer --> KE

' ---- Couche clés ----
Core --> XOR
Core --> LMKS
Core --> KEK
Core --> VAULT
Core --> INTEG
Core --> MUT

' ---- Défense (transversale) ----
Core ..> DEF : <<uses>>
Core ..> SECC : <<uses>>
XOR ..> DEF : zero_all_fragments()
VAULT ..> DEF : secure_zero()

' ---- Stockage ----
LMKS --> LMKFile
VAULT --> VaultFile
Core --> PVVFile

' ---- OpenSSL ----
PIN --> OSSL
MAC --> OSSL
EMV --> OSSL
KE --> OSSL
LMKS --> OSSL
KEK --> OSSL
XOR --> OSSL
INTEG --> OSSL

@enduml


' ============================================================
' 9. DIAGRAMME DE SÉQUENCE — Mutation des Fragments LMK
' ============================================================

@startuml Sequence_Mutation
!theme plain
skinparam sequenceArrowColor #2980B9
skinparam sequenceLifeLineBorderColor #1A5276
skinparam sequenceParticipantBackgroundColor #EBF5FB
skinparam sequenceParticipantBorderColor #2980B9

title Diagramme de Séquence — Mutation Cyclique des Fragments LMK

participant "Administrateur\n/ Scheduler" as Admin
participant "payhsm_core" as Core
participant "XorFragment" as Frag
participant "Integrity" as Integ
participant "Mutation" as Mut
participant "DefenseModule" as Def

Admin -> Core : payhsm_mutate_lmk_fragments()
activate Core

Core -> Integ : integrity_verify_fragments(P1, P2, P3)
note right : Vérification HMAC-SHA256\navant mutation
Integ --> Core : 0 (fragments valides)

Core -> Frag : recompose_for_op(lmk_check)
note right : Vérification LMK reconstruite
Frag --> Core : lmk_check[32]

Core -> Def : secure_zero(lmk_check, 32)

Core -> Mut : mutation_apply(P1, P2, P3)
note right : XOR P1 et P3 avec nonce aléatoire\nRe-alloue P2 (nouvelle adresse heap)\nMet à jour HMAC de référence\nIncrément compteur mutation

Mut --> Core : 0 (OK)

Core -> Integ : integrity_verify_fragments(P1_new, P2_new, P3_new)
note right : Vérification post-mutation
Integ --> Core : 0 (intégrité confirmée)

Core -> Mut : mutation_stats_get(stats)
Mut --> Core : {count=N, last_ts=T}

Core --> Admin : "Mutation N appliquée — fragments valides"
deactivate Core

@enduml

